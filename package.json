{
  "name": "@antschni/afetch",
  "version": "1.0.0",
  "description": "minimal axios-like http client for node.js and browser",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "scripts": {
    "test": "vitest",
    "pack": "npm pack --pack-destination ./build",
    "build": "tsup src/index.ts --format cjs,esm --out-dir ./dist --tsconfig tsconfig.json --dts --clean",
    "prepack": "npm run build",
    "publish": "npm publish --access public"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antschni/afetch.git"
  },
  "keywords": [
    "http client",
    "node.js",
    "browser",
    "fetch",
    "axios"
  ],
  "author": "Anton Schnitzer",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/antschni/afetch/issues"
  },
  "homepage": "https://github.com/antschni/afetch#readme",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
